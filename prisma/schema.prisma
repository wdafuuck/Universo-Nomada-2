generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  LOST
}

model Destination {
  id            String   @id
  name          String
  subtitle      String
  description   String
  image         String
  tag           String
  tagColor      String
  icon          String
  category      String
  price         Int
  originalPrice Int?
  duration      String
  highlights    String[] @default([])
  includes      String[] @default([])
  notIncludes   String[] @default([])
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, order])
  @@index([category])
}

model Promotion {
  id            Int      @id @default(autoincrement())
  title         String
  subtitle      String
  discount      String
  destination   String
  validUntil    DateTime
  originalPrice Int
  discountPrice Int
  emoji         String   @default("🔥")
  image         String?
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, validUntil])
}

model Lead {
  id          Int        @id @default(autoincrement())
  nombre      String
  email       String
  telefono    String
  destino     String?
  mensaje     String?
  status      LeadStatus @default(NEW)
  notes       String?
  contactedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, createdAt])
  @@index([email])
}
